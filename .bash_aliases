# core
alias config='vim ~/dotfiles/.zshrc'
alias vimconfig='vim ~/dotfiles/.vimrc'
alias aliases='vim ~/dotfiles/.bash_aliases'
alias local_aliases='vim ~/.bash_aliases_local'
alias functions='vim ~/dotfiles/.bash_functions'
alias local_functions='vim ~/.bash_functions_local'

# source
alias reload='source ~/.zshrc'

# locations
alias desk='cd ~/Desktop'
alias codes='cd ~/codes'

# git
alias gst='git status'
alias gfp='git fetch --prune'
alias glt='git log --oneline --decorate --graph --all'

# docker
alias up='docker compose up -d'
alias down='docker compose down'

# python
alias popy='poetry run python3'
alias poipy='poetry run ipython3'
alias uvpy='uv run python3'
alias uvipy='uv run ipython3'

# cargo
alias cb='cargo build'
alias cr='cargo run'
alias ct='cargo test'
alias cbn='cargo bench'

